---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
  variant: 'desktop' | 'mobile';
}

const { headings, variant } = Astro.props;
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{tocHeadings.length > 0 && variant === 'desktop' && (
  <nav class="toc toc-desktop" aria-label="Table of contents">
    <p class="toc-title">On this page</p>
    <ul class="toc-list">
      {tocHeadings.map(h => (
        <li class={`toc-item toc-depth-${h.depth}`}>
          <a href={`#${h.slug}`} class="toc-link" data-heading={h.slug}>
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

{tocHeadings.length > 0 && variant === 'mobile' && (
  <div class="toc-mobile" id="toc-mobile">
    <button class="toc-toggle" id="toc-toggle" aria-label="Toggle table of contents">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="15" y2="12"/>
        <line x1="3" y1="18" x2="9" y2="18"/>
      </svg>
      <span class="toc-toggle-text">On this page</span>
    </button>
    <div class="toc-panel" id="toc-panel">
      <ul class="toc-list">
        {tocHeadings.map(h => (
          <li class={`toc-item toc-depth-${h.depth}`}>
            <a href={`#${h.slug}`} class="toc-link" data-heading={h.slug}>
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
)}

<style>
  /* ===================================
     Desktop — Sticky Sidebar
     =================================== */
  .toc-desktop {
    position: sticky;
    top: 6rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  .toc-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
    padding-left: 0.75rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin: 0;
  }

  .toc-link {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all var(--transition-fast);
    line-height: 1.4;
  }

  .toc-link:hover {
    color: var(--text-primary);
    border-left-color: var(--border-color-hover);
  }

  .toc-link.active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    font-weight: 500;
  }

  .toc-depth-3 .toc-link {
    padding-left: 1.5rem;
    font-size: 0.75rem;
  }

  /* ===================================
     Mobile — Floating Capsule
     =================================== */
  .toc-mobile {
    display: none;
  }

  @media (max-width: 1080px) {
    .toc-mobile {
      display: block;
      position: fixed;
      bottom: 4.5rem;
      right: 1rem;
      z-index: 900;
    }

    .toc-toggle {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: var(--nav-bg);
      backdrop-filter: var(--nav-backdrop);
      -webkit-backdrop-filter: var(--nav-backdrop);
      border: 1px solid var(--nav-border);
      border-radius: 9999px;
      box-shadow: var(--shadow-md);
      color: var(--text-secondary);
      font-size: 0.8125rem;
      cursor: pointer;
      transition: all var(--transition-fast);
      white-space: nowrap;
    }

    .toc-toggle:hover {
      color: var(--color-primary);
      border-color: var(--color-primary);
    }

    .toc-toggle.open {
      color: var(--color-primary);
      border-color: var(--color-primary);
    }

    .toc-panel {
      display: none;
      position: absolute;
      bottom: calc(100% + 0.5rem);
      right: 0;
      min-width: 220px;
      max-width: 280px;
      max-height: 50vh;
      overflow-y: auto;
      padding: 0.75rem;
      background: var(--nav-bg);
      backdrop-filter: var(--nav-backdrop);
      -webkit-backdrop-filter: var(--nav-backdrop);
      border: 1px solid var(--nav-border);
      border-radius: 16px;
      box-shadow: var(--shadow-lg);
    }

    .toc-panel.open {
      display: block;
    }

    .toc-panel .toc-link {
      padding: 0.5rem 0.75rem;
      font-size: 0.8125rem;
    }

    .toc-panel .toc-depth-3 .toc-link {
      padding-left: 1.5rem;
      font-size: 0.75rem;
    }
  }
</style>

<script>
  function initTOC() {
    // IntersectionObserver for active heading tracking
    const headingElements = document.querySelectorAll('.post-content :where(h2, h3)');
    const tocLinks = document.querySelectorAll('.toc-link[data-heading]');

    if (headingElements.length > 0 && tocLinks.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries.filter(e => e.isIntersecting);
          if (visibleEntries.length > 0) {
            const activeId = visibleEntries[0].target.id;
            tocLinks.forEach(link => {
              link.classList.toggle('active', link.getAttribute('data-heading') === activeId);
            });
          }
        },
        {
          rootMargin: '-80px 0px -60% 0px',
          threshold: 0,
        }
      );

      headingElements.forEach(heading => {
        if (heading.id) observer.observe(heading);
      });
    }

    // Mobile TOC toggle
    const tocToggle = document.getElementById('toc-toggle');
    const tocPanel = document.getElementById('toc-panel');

    tocToggle?.addEventListener('click', () => {
      tocToggle.classList.toggle('open');
      tocPanel?.classList.toggle('open');
    });

    // Close panel when clicking a link
    tocPanel?.querySelectorAll('.toc-link').forEach(link => {
      link.addEventListener('click', () => {
        tocToggle?.classList.remove('open');
        tocPanel?.classList.remove('open');
      });
    });

    // Close panel when clicking outside
    document.addEventListener('click', (e) => {
      const mobile = document.getElementById('toc-mobile');
      if (mobile && !mobile.contains(e.target as Node)) {
        tocToggle?.classList.remove('open');
        tocPanel?.classList.remove('open');
      }
    });
  }

  // Initialize on page load (including first load with ClientRouter)
  document.addEventListener('astro:page-load', initTOC);
</script>
