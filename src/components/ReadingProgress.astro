---
// Reading Progress Bar — thin line at the top of the viewport
// Grows left-to-right as the user scrolls through the article.
---

<div class="reading-progress" id="reading-progress"></div>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-primary);
    transform-origin: left;
    transform: scaleX(0);
    z-index: 1100;
    pointer-events: none;
  }
</style>

<script>
  function initReadingProgress() {
    function updateProgress() {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;

      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? scrollTop / docHeight : 0;

      bar.style.transform = `scaleX(${Math.min(progress, 1)})`;
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  // Initialize on page load (including first load with ClientRouter)
  document.addEventListener('astro:page-load', initReadingProgress);
</script>
