---
interface Props {
  type: 'note' | 'warning' | 'tip' | 'info';
  title?: string;
}

const { type, title } = Astro.props;

const icons: Record<string, string> = {
  note: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>',
  warning: '<path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>',
  tip: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>',
  info: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>',
};

const defaultTitles: Record<string, string> = {
  note: 'Note',
  warning: 'Warning',
  tip: 'Tip',
  info: 'Info',
};
---

<div class={`callout callout-${type}`}>
  <div class="callout-header">
    <div class="callout-icon">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <Fragment set:html={icons[type]} />
      </svg>
    </div>
    <span class="callout-title">{title || defaultTitles[type]}</span>
  </div>
  <div class="callout-body">
    <slot />
  </div>
</div>

<style>
  .callout {
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 8px;
    border-left: 4px solid;
  }

  .callout-header {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    margin-bottom: 0.75rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.8125rem;
  }

  .callout-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .callout-title {
    margin: 0;
  }

  .callout-body {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .callout-body :global(p) {
    margin: 0;
  }

  .callout-body :global(p + p) {
    margin-top: 0.5rem;
  }

  .callout-body :global(ul),
  .callout-body :global(ol) {
    margin: 0.5rem 0 0 1.25rem;
    padding: 0;
  }

  .callout-body :global(li) {
    margin-bottom: 0.25rem;
  }

  .callout-body :global(code) {
    font-size: 0.8125rem;
  }

  /* Note - Blue */
  .callout-note {
    background: rgba(59, 130, 246, 0.08);
    border-color: #3b82f6;
  }

  .callout-note .callout-header {
    background: rgba(59, 130, 246, 0.15);
    color: #2563eb;
  }

  .callout-note .callout-icon {
    color: #3b82f6;
  }

  html.dark .callout-note {
    background: rgba(59, 130, 246, 0.15);
  }

  html.dark .callout-note .callout-header {
    background: rgba(59, 130, 246, 0.25);
    color: #60a5fa;
  }

  /* Warning - Orange */
  .callout-warning {
    background: rgba(249, 115, 22, 0.08);
    border-color: #f97316;
  }

  .callout-warning .callout-header {
    background: rgba(249, 115, 22, 0.15);
    color: #ea580c;
  }

  .callout-warning .callout-icon {
    color: #f97316;
  }

  html.dark .callout-warning {
    background: rgba(249, 115, 22, 0.15);
  }

  html.dark .callout-warning .callout-header {
    background: rgba(249, 115, 22, 0.25);
    color: #fb923c;
  }

  /* Tip - Green */
  .callout-tip {
    background: rgba(34, 197, 94, 0.08);
    border-color: #22c55e;
  }

  .callout-tip .callout-header {
    background: rgba(34, 197, 94, 0.15);
    color: #16a34a;
  }

  .callout-tip .callout-icon {
    color: #22c55e;
  }

  html.dark .callout-tip {
    background: rgba(34, 197, 94, 0.15);
  }

  html.dark .callout-tip .callout-header {
    background: rgba(34, 197, 94, 0.25);
    color: #4ade80;
  }

  /* Info - Purple */
  .callout-info {
    background: rgba(139, 92, 246, 0.08);
    border-color: #8b5cf6;
  }

  .callout-info .callout-header {
    background: rgba(139, 92, 246, 0.15);
    color: #7c3aed;
  }

  .callout-info .callout-icon {
    color: #8b5cf6;
  }

  html.dark .callout-info {
    background: rgba(139, 92, 246, 0.15);
  }

  html.dark .callout-info .callout-header {
    background: rgba(139, 92, 246, 0.25);
    color: #a78bfa;
  }
</style>
