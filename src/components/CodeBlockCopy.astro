---
// Code block copy button — adds copy functionality and title display to all code blocks
---

<script>
  function initCodeBlockCopy() {
    // Add copy button and title to all code blocks
    document.querySelectorAll('pre').forEach((pre) => {
      // Skip if already processed
      if (pre.querySelector('.copy-button')) return;

      // Get title from data-title attribute
      const title = pre.getAttribute('data-title');

      // Add title badge if present
      if (title && !pre.querySelector('.code-title')) {
        const titleEl = document.createElement('div');
        titleEl.className = 'code-title';
        titleEl.textContent = title;
        pre.insertBefore(titleEl, pre.firstChild);
      }

      // Add copy button
      const button = document.createElement('button');
      button.className = 'copy-button';
      button.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span>Copy</span>
      `;

      button.addEventListener('click', async () => {
        const codeEl = pre.querySelector('code');
        if (!codeEl) return;

        try {
          await navigator.clipboard.writeText(codeEl.textContent || '');
          button.classList.add('copied');
          button.querySelector('span').textContent = 'Copied!';

          setTimeout(() => {
            button.classList.remove('copied');
            button.querySelector('span').textContent = 'Copy';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });

      pre.style.position = 'relative';
      pre.appendChild(button);
    });
  }

  document.addEventListener('astro:page-load', initCodeBlockCopy);
</script>

<style>
  /* Title badge - capsule style */
  :global(pre .code-title) {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 9999px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    color: var(--text-secondary);
    z-index: 1;
    max-width: calc(100% - 5rem);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Copy button */
  :global(pre .copy-button) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    background: var(--nav-bg);
    backdrop-filter: var(--nav-backdrop);
    -webkit-backdrop-filter: var(--nav-backdrop);
    border: 1px solid var(--nav-border);
    border-radius: 6px;
    color: var(--text-secondary);
    font-size: 0.75rem;
    font-family: inherit;
    cursor: pointer;
    opacity: 0;
    transition: all var(--transition-fast);
  }

  :global(pre:hover .copy-button) {
    opacity: 1;
  }

  :global(pre .copy-button:hover) {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  :global(pre .copy-button.copied) {
    color: #22c55e;
    border-color: #22c55e;
  }

  /* Adjust code padding when title is present */
  :global(pre:has(.code-title)) {
    padding-top: 2.5rem;
  }

  :global(pre:has(.code-title) code) {
    padding-top: 0;
  }
</style>
