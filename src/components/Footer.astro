---
import { siteConfig } from '../config';

const year = new Date().getFullYear();
---

<footer class="capsule-footer" transition:name="footer">
  <div class="footer-inner">
    <p class="footer-text">
      © {year} {siteConfig.title}
    </p>
    <div class="footer-divider"></div>
    <div class="footer-links">
      {siteConfig.social.github && (
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      )}
      {siteConfig.features?.rss && (
        <a href="/rss.xml" target="_blank" aria-label="RSS">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="6.18" cy="17.82" r="2.18"/>
            <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</footer>

<style>
  .capsule-footer {
    margin-top: 4rem;
    padding: 0 1.5rem 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.625rem 1.5rem;
    max-width: 720px;
    margin: 0 auto;
    background: var(--nav-bg);
    backdrop-filter: var(--nav-backdrop);
    -webkit-backdrop-filter: var(--nav-backdrop);
    border: 1px solid var(--nav-border);
    border-radius: 9999px;
    box-shadow: var(--shadow-sm);
  }

  .footer-text {
    color: var(--text-tertiary);
    font-size: 0.8125rem;
    margin: 0;
    white-space: nowrap;
  }

  .footer-divider {
    width: 1px;
    height: 14px;
    background: var(--border-color);
    flex-shrink: 0;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .footer-inner {
      gap: 0.75rem;
      padding: 0.5rem 1rem;
    }

    .footer-text {
      font-size: 0.75rem;
    }
  }
</style>
