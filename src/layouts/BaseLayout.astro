---
import '../styles/global.css';
import '../styles/callout.css';
import { siteConfig } from '../config';
import { ClientRouter } from 'astro:transitions';
import BackToTop from '../components/BackToTop.astro';
import CodeBlockCopy from '../components/CodeBlockCopy.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description
} = Astro.props;
---

<!DOCTYPE html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <ClientRouter />

    {/* Theme detection script - runs before paint to prevent flash */}
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme') || 'auto';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const effectiveTheme = saved === 'auto' ? (prefersDark ? 'dark' : 'light') : saved;
        document.documentElement.setAttribute('data-theme', saved);
        document.documentElement.classList.add(effectiveTheme);
      })();

      // Re-apply theme after View Transitions swap (before page is visible)
      document.addEventListener('astro:after-swap', () => {
        const saved = localStorage.getItem('theme') || 'auto';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const effectiveTheme = saved === 'auto' ? (prefersDark ? 'dark' : 'light') : saved;
        document.documentElement.setAttribute('data-theme', saved);
        document.documentElement.classList.remove('dark', 'light');
        document.documentElement.classList.add(effectiveTheme);
      });
    </script>
  </head>
  <body>
    <slot />
    {siteConfig.features?.backToTop && <BackToTop />}
    <CodeBlockCopy />
  </body>
</html>
