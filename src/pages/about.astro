---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About - CapsuleX">
  <Navigation />

  <main class="container" style="padding-top: 6rem;">
    <article class="about">
      <h1>About</h1>
      <p>
        CapsuleX is a minimal blog theme built with Astro.
        It features a clean, modern design with capsule-shaped navigation
        and automatic dark/light mode support.
      </p>
      <h2>Features</h2>
      <ul>
        <li>Capsule floating navigation</li>
        <li>Automatic dark/light mode</li>
        <li>Fast page transitions</li>
        <li>Mobile responsive</li>
        <li>SEO friendly</li>
      </ul>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about {
    max-width: 600px;
    padding: 2rem 0;
  }

  .about h1 {
    margin-bottom: 1.5rem;
  }

  .about h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .about ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .about li {
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
</style>
